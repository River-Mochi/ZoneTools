{
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "webpack",
    "dev": "webpack --watch",
    "update": "npx create-csii-ui-mod update",
    "postupdate": "node tools/patch-tsconfig.js",
    "delete": "npx create-csii-ui-mod delete",
    "clean": "npx create-csii-ui-mod clean",
    "lint": "eslint \"src/**/*.{ts,tsx,js,jsx}\""
  },
  "exclude": [
    "node_modules",
    "build"
  ],
  "_notes": {
    "react, react-dom": "Pinned to the version the game uses 18.3.1, cannot change.",
    "sass, sass-embedded": "Do not upgrade past 1.78.x (cohtml parsing)."
  },

  "dependencies": {
    "classnames": "2.3.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-draggable": "^4.4.6",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "18.0.26",
    "@types/react-dom": "18.0.9",
    "css-loader": "6.7.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "mini-css-extract-plugin": "2.7.0",
    "sass": "~1.78.0",
    "sass-loader": "14.2.1",
    "style-loader": "^3.3.3",
    "swc-loader": "0.2.3",
    "terser-webpack-plugin": "^5.3.16",
    "ts-loader": "^9.5.4",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "webpack": "5.105.4",
    "webpack-cli": "^6.0.1"
  }
}
